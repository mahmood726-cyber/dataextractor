{
  "name": "rctextractor",
  "version": "5.1.0",
  "description": "AI-enhanced extraction engine for randomized controlled trial (RCT) data from medical literature. Extracts effect measures, population data, outcomes, risk of bias, and GRADE assessments for systematic reviews and meta-analysis.",
  "main": "index.js",
  "module": "index.js",
  "types": "types.d.ts",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "require": "./index.js",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./pdf": {
      "types": "./types.d.ts",
      "require": "./pdf_extractor.js",
      "import": "./pdf_extractor.js"
    },
    "./batch": {
      "require": "./lib/batch.js",
      "import": "./lib/batch.js"
    },
    "./lib": {
      "require": "./lib/index.js",
      "import": "./lib/index.js"
    },
    "./audit": {
      "require": "./lib/audit.js",
      "import": "./lib/audit.js"
    },
    "./cli": "./extract_cli.js",
    "./scraper": "./scraper/index.js",
    "./graphql": {
      "require": "./graphql/index.js",
      "import": "./graphql/index.js"
    },
    "./websocket": {
      "require": "./websocket/index.js",
      "import": "./websocket/index.js"
    },
    "./websocket/client": {
      "require": "./websocket/client.js",
      "import": "./websocket/client.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "rctextract": "./extract_cli.js",
    "rct-pdf": "./pdf_extractor.js",
    "rct-split": "./split_papers.js",
    "rct-split-accurate": "./accurate_paper_splitter.js",
    "rct-server": "./server/server.js",
    "rct-scrape": "./scraper/scraper_cli.js",
    "rct-graphql": "./graphql/server.js",
    "rct-ws": "./websocket/ws_server.js"
  },
  "scripts": {
    "test": "node run_tests.js",
    "test:watch": "node --watch run_tests.js",
    "test:server": "node tests/server.test.js",
    "test:e2e": "node tests/e2e/run_all.js",
    "test:e2e:pdf": "node tests/e2e/pdf_extraction.test.js",
    "test:e2e:api": "node tests/e2e/api_server.test.js",
    "test:e2e:cli": "node tests/e2e/cli.test.js",
    "test:e2e:batch": "node tests/e2e/batch.test.js",
    "extract": "node extract_cli.js",
    "extract:pdf": "node pdf_extractor.js",
    "split": "node split_papers.js",
    "split:accurate": "node accurate_paper_splitter.js",
    "validate": "node validation_v49.js",
    "benchmark": "node benchmark_fields.js",
    "server": "node server/server.js",
    "server:dev": "node --watch server/server.js",
    "server:prod": "NODE_ENV=production node server/server.js",
    "lint": "eslint . --ext .js --max-warnings 50",
    "format": "echo \"Add prettier for formatting\"",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['dist','coverage','.nyc_output'].forEach(d=>{try{fs.rmSync(d,{recursive:true})}catch{}})\"",
    "prepublishOnly": "npm run test && npm run typecheck",
    "version": "npm run test",
    "help": "node extract_cli.js --help",
    "help:pdf": "node pdf_extractor.js --help",
    "help:split": "node split_papers.js --help",
    "help:server": "echo 'RCTExtractor API Server - Run: npm run server'",
    "scrape": "node scraper/scraper_cli.js",
    "help:scrape": "node scraper/scraper_cli.js --help",
    "graphql": "node graphql/server.js",
    "graphql:dev": "node --watch graphql/server.js",
    "graphql:prod": "NODE_ENV=production node graphql/server.js",
    "help:graphql": "echo 'RCTExtractor GraphQL API - Run: npm run graphql'"
  },
  "keywords": [
    "rct",
    "randomized-controlled-trial",
    "meta-analysis",
    "systematic-review",
    "clinical-trial",
    "medical-research",
    "data-extraction",
    "evidence-synthesis",
    "nlp",
    "natural-language-processing",
    "hazard-ratio",
    "odds-ratio",
    "relative-risk",
    "confidence-interval",
    "risk-of-bias",
    "grade",
    "cochrane",
    "pdf-extraction",
    "medical-nlp",
    "clinical-data",
    "pico",
    "prisma",
    "metafor",
    "healthcare",
    "research-synthesis",
    "web-scraping",
    "pubmed",
    "nejm",
    "lancet",
    "bmj",
    "jama",
    "graphql",
    "apollo-server"
  ],
  "author": {
    "name": "RCTExtractor Team",
    "email": "contact@rctextractor.org",
    "url": "https://github.com/rctextractor"
  },
  "contributors": [
    {
      "name": "RCTExtractor Contributors",
      "url": "https://github.com/rctextractor/rctextractor/graphs/contributors"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rctextractor/rctextractor.git"
  },
  "bugs": {
    "url": "https://github.com/rctextractor/rctextractor/issues"
  },
  "homepage": "https://github.com/rctextractor/rctextractor#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/rctextractor"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "index.js",
    "RCTExtractor_v4_8_AI.js",
    "RCTExtractor_v4_7.js",
    "LocalAI.js",
    "pdf_extractor.js",
    "extract_cli.js",
    "split_papers.js",
    "accurate_paper_splitter.js",
    "types.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "server/",
    "scraper/",
    "lib/",
    "graphql/"
  ],
  "sideEffects": false,
  "preferGlobal": true,
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "ora": "^5.4.1",
    "pdf-parse": "^1.1.4",
    "readline": "^1.3.0",
    "@apollo/server": "^4.10.0",
    "@graphql-tools/schema": "^10.0.2",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "graphql-subscriptions": "^2.0.0",
    "graphql-upload": "^16.0.2",
    "graphql-ws": "^5.14.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "supertest": "^6.3.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
